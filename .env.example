# ── Server ports ─────────────────────────────────────────────────────
# In production, these vars are not used:
# - BACKEND_PORT is overridden by the hosting platform's $PORT env var
#   (see backend/src/your_project_name/settings.py for the override logic).
# - FRONTEND_PORT is not used — the frontend is compiled into static
#   files and served by the backend on the same port.
BACKEND_PORT=8000
FRONTEND_PORT=5173

# ── Database (libsql) ──────────────────────────────────────────────────
# - The default local libSQL database lives at backend/data/app.db.
# - Set DATABASE_URL in production to use Turso/libSQL or another supported DB.
# - Leave DATABASE_AUTH_TOKEN empty when the database does not require auth.
DATABASE_URL=sqlite+libsql:///data/app.db
# DATABASE_URL=libsql://your-database-org.turso.io
# DATABASE_AUTH_TOKEN=your-database-token

# ── Clerk authentication ───────────────────────────────────────────────
# Set NO_AUTH=true to bypass Clerk locally. If NO_AUTH is unset and
# CLERK_PUBLISHABLE_KEY is also unset, auth is bypassed automatically.
# The frontend sends `Bearer fake-user-uid`; the backend treats the bearer
# value as the current user ID. Set NO_AUTH=false to require Clerk explicitly.
# NO_AUTH=false
#
# Obtain keys from the Clerk Dashboard → API Keys:
#   https://dashboard.clerk.com/~/api-keys
#
# CLERK_SECRET_KEY        — Your secret key (sk_live_... or sk_test_...).
#                           Used server-side for JWT verification. Never
#                           expose to the browser.
# CLERK_PUBLISHABLE_KEY   — Your publishable key (pk_live_... or pk_test_...).
#                           Safe to expose to the frontend.
#
# CLERK_ISSUER            — Your Frontend API URL, listed on the same
#                           API Keys page. Used to validate the `iss`
#                           claim and to locate the JWKS endpoint at
#                           {issuer}/.well-known/jwks.json. Typically:
#                             https://clerk.{your-app}.com
#                             https://{subdomain}.clerk.accounts.dev
#
# CLERK_AUTHORIZED_PARTIES — Comma-separated list of allowed origins for
#                           the `azp` claim. Set this to every origin
#                           that can legitimately generate Clerk tokens.
#                           In development:
#                             http://localhost:5173,http://localhost:8000
#                           In production:
#                             https://your-app.onrender.com
# CLERK_SECRET_KEY=sk_test_...
# CLERK_PUBLISHABLE_KEY=pk_test_...
# CLERK_ISSUER=https://clerk.your-app.com
# CLERK_AUTHORIZED_PARTIES=http://localhost:5173,http://localhost:8000

# ── Basic authentication (production guard) ────────────────────────────
# When both BASIC_AUTH_USERNAME and BASIC_AUTH_PASSWORD are set, every
# request to the backend requires valid HTTP Basic Auth credentials in
# the Authorization header. This acts as a simple gate to prevent
# unauthorised access to your deployed instance.
#
# If either variable is left empty, the guard is completely disabled and
# all routes remain open (default behaviour for local development).
#
# Example:
#   BASIC_AUTH_USERNAME=admin
#   BASIC_AUTH_PASSWORD=your-secure-password-here
# BASIC_AUTH_USERNAME=
# BASIC_AUTH_PASSWORD=
